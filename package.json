{
  "name": "localterminal-mcp-lite",
  "version": "0.5.0",
  "private": true,
  "description": "Lite local WebDev MCP with dual-session collaboration, Apps and Actions adapters, extension tools, and a terminal UI.",
  "type": "module",
  "license": "UNLICENSED",
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "localterminal-lite": "dist/cli.js"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "dev": "bun run src/cli.ts",
    "start": "bun run dist/cli.js",
    "test": "bun run build && bun test --timeout 30000 test/*.test.mjs",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "0.4.5",
    "@opentui/keymap": "0.4.5",
    "@opentui/react": "0.4.5",
    "express": "^5.2.1",
    "react": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "19.2.14",
    "typescript": "5.9.3"
  }
}
