{
  "name": "localterminal-mcp-lite",
  "version": "0.4.1",
  "private": true,
  "description": "Lite local WebDev MCP with dual-session collaboration, Apps and Actions adapters, extension tools, and a terminal UI.",
  "type": "module",
  "license": "UNLICENSED",
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
